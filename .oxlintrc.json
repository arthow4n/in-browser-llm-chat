{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "vitest", "typescript"],
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "settings": {
    "react": {
      "version": "19.0.0"
    }
  },
  "rules": {
    "react/jsx-key": "error",
    "react/jsx-no-target-blank": "error",
    "react/no-direct-mutation-state": "error",
    "typescript/no-explicit-any": "error"
  }
}
